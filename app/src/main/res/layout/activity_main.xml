<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#F6EFEA"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:background="@android:color/transparent"
        android:title="Inventaris"
        android:titleTextColor="@android:color/black"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- CONTENT -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="56dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- SUMMARY CARD -->
        <LinearLayout
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- TOTAL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                android:layout_width="0dp"
                android:layout_height="100dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/tvTotalBarang"
                        android:text="0"
                        android:textStyle="bold"
                        android:textSize="18sp"/>

                    <TextView android:text="Total Barang"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STOK RENDAH -->
            <com.google.android.material.card.MaterialCardView
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                android:layout_width="0dp"
                android:layout_height="100dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/tvStokRendah"
                        android:text="0"
                        android:textColor="#FFA000"
                        android:textStyle="bold"/>

                    <TextView android:text="Stok Rendah"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- STOK HABIS -->
            <com.google.android.material.card.MaterialCardView
                android:layout_weight="1"
                android:layout_margin="4dp"
                app:cardCornerRadius="16dp"
                android:layout_width="0dp"
                android:layout_height="100dp">

                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <TextView
                        android:id="@+id/tvStokHabis"
                        android:text="0"
                        android:textColor="#D32F2F"
                        android:textStyle="bold"/>

                    <TextView android:text="Stok Habis"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- SEARCH -->
        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchView"
            android:queryHint="Cari barang..."
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- CATEGORY -->
        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupCategory"
            app:singleSelection="true"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <!-- LOW STOCK BANNER -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/bannerLowStock"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            app:cardBackgroundColor="#FFF3E0"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvLowStockInfo"
                android:padding="12dp"
                android:text="0 barang hampir habis"/>
        </com.google.android.material.card.MaterialCardView>

        <!-- LIST -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_marginTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <!-- EMPTY -->
        <TextView
            android:id="@+id/tvEmpty"
            android:text="Belum ada barang"
            android:gravity="center"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#FF6B35"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>